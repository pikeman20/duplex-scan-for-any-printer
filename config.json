{
  "name": "Scan Agent",
  "version": "1.0.0",
  "slug": "scan-agent",
  "description": "Brother Scanner FTP receiver with automatic PDF generation and duplex printing support",
  "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ports": {
    "2121/tcp": 2121,
    "8099/tcp": 8099,
    "30000-30009/tcp": null
  },
  "ports_description": {
    "2121/tcp": "FTP control port for scanner uploads",
    "8099/tcp": "Web UI dashboard",
    "30000-30009/tcp": "FTP passive mode data ports"
  },
  "map": [
    "config:rw",
    "share:rw"
  ],
  "options": {
    "log_level": "info",
    "session_timeout_seconds": 300,
    "delete_inbox_files_after_process": true,
    "test_mode": false,
    "ftp": {
      "username": "",
      "password": ""
    },
    "printer": {
      "name": "",
      "ip": "",
      "enabled": false
    },
    "telegram": {
      "enabled": false,
      "bot_token": "",
      "authorized_users": [],
      "notify_chat_ids": [],
      "notify_on_session_ready": true
    }
  },
  "schema": {
    "log_level": "list(trace|debug|info|warning|error)?",
    "session_timeout_seconds": "int(30,3600)?",
    "delete_inbox_files_after_process": "bool?",
    "test_mode": "bool?",
    "ftp": {
      "username": "str?",
      "password": "password?"
    },
    "printer": {
      "name": "str?",
      "ip": "str?",
      "enabled": "bool"
    },
    "telegram": {
      "enabled": "bool",
      "bot_token": "password?",
      "authorized_users": ["str?"],
      "notify_chat_ids": ["str?"],
      "notify_on_session_ready": "bool?"
    }
  },
  "image": "ghcr.io/yourusername/hassio-scan-agent-{arch}",
  "url": "https://github.com/yourusername/hassio-scan-agent",
  "ingress": false,
  "panel_icon": "mdi:scanner",
  "hassio_api": true,
  "homeassistant_api": false,
  "host_network": false,
  "full_access": false,
  "apparmor": true
}
